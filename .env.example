# Local overrides for this project (optional). Copy to .env if you need them.
# The agent already reads the shared store at ~/.config/secrets/secrets.env,
# so you usually do NOT need a local .env at all.

# Override the model (LiteLLM format: "<provider>/<model-id>", or a bare
# Gemini model name like "gemini-2.0-flash").
# ADK_MODEL=anthropic/claude-haiku-4-5-20251001

# Only needed if you are NOT using the central store:
# ANTHROPIC_API_KEY=sk-ant-...
